# ============================================================
# Campus Commute — Frontend Environment Variables
# Copy this file to .env and fill in the values
# For Vercel: add these in Project Settings → Environment Variables
# ============================================================

# Backend API URL — your Render deployment URL (no trailing slash)
# Example: https://campus-commute-api.onrender.com
VITE_BACKEND_URL=https://your-render-api.onrender.com

# Google OAuth Client ID (from Google Cloud Console)
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
