# ============================================================
# Campus Commute — Backend Environment Variables
# Copy this file to .env and fill in the values
# ============================================================

# Server
# Note: Render automatically sets PORT — do NOT set it manually in Render dashboard
BACKEND_PORT=8000

# MongoDB Atlas connection string
MONGODB_URI="mongodb+srv://<username>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority"

# JWT Secret — use a long random string in production
JWT_SECRET="your-very-strong-jwt-secret-here"

# Gmail credentials for OTP emails
EMAIL=your-email@gmail.com
EMAIL_PASS="xxxx xxxx xxxx xxxx"

# Google OAuth Client ID (from Google Cloud Console)
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Frontend URL — your Vercel deployment URL (no trailing slash)
# Example: https://campus-commute.vercel.app
FRONTEND_URL=https://your-vercel-app.vercel.app
